{
  "name": "approval-basic",
  "description": "Approval voting, clear single winner with a distinct runner-up.",
  "source": "synthetic",
  "input": {
    "algorithms": ["approval"],
    "include_fptp": false,
    "candidates": [
      { "id": "cand-1", "name": "Alice", "position": 0 },
      { "id": "cand-2", "name": "Bob", "position": 1 },
      { "id": "cand-3", "name": "Carol", "position": 2 }
    ],
    "ballots": [
      { "payload": { "approval": ["cand-1", "cand-2"] } },
      { "payload": { "approval": ["cand-1"] } },
      { "payload": { "approval": ["cand-1", "cand-3"] } },
      { "payload": { "approval": ["cand-2"] } }
    ]
  },
  "expected": [
    {
      "algorithm": "approval",
      "result_data": {
        "winners": ["Alice"],
        "winner": "Alice",
        "runner_up": "Bob",
        "tallies": { "Alice": 3, "Bob": 2, "Carol": 1 }
      }
    }
  ]
}
