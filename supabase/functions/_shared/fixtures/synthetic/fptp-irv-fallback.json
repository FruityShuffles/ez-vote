{
  "name": "fptp-irv-fallback",
  "description": "When IRV is enabled and a ballot has no explicit payload.fptp, FPTP falls back to irv[0]. Also exercises IRV's multi-candidate final elimination producing an '&'-joined runner_up.",
  "source": "synthetic",
  "input": {
    "algorithms": ["irv"],
    "include_fptp": true,
    "candidates": [
      { "id": "cand-1", "name": "Alice", "position": 0 },
      { "id": "cand-2", "name": "Bob", "position": 1 },
      { "id": "cand-3", "name": "Carol", "position": 2 }
    ],
    "ballots": [
      { "payload": { "irv": ["cand-1", "cand-2"] } },
      { "payload": { "irv": ["cand-1", "cand-3"] } },
      { "payload": { "irv": ["cand-2", "cand-1"] } },
      { "payload": { "irv": ["cand-3", "cand-2"] } }
    ]
  },
  "expected": [
    {
      "algorithm": "irv",
      "result_data": {
        "winners": ["Alice"],
        "winner": "Alice",
        "runner_up": "Bob & Carol",
        "rounds": [
          {
            "counts": { "Alice": 2, "Bob": 1, "Carol": 1 },
            "eliminated": ["Bob", "Carol"]
          }
        ]
      }
    },
    {
      "algorithm": "fptp",
      "result_data": {
        "winners": ["Alice"],
        "winner": "Alice",
        "runner_up": "Bob",
        "tallies": { "Alice": 2, "Bob": 1, "Carol": 1 }
      }
    }
  ]
}
